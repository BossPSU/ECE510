# =============================================================================
# .gitignore for the ECE 410/510 chiplet project
# =============================================================================

# ---- QuestaSim / ModelSim ----
# Per-run work library (generated by vlib/vlog/vmap/vopt)
work/
**/work/
# Per-directory simulator config (re-created by every vmap)
modelsim.ini
**/modelsim.ini
# Default GUI/batch transcript (we keep the explicitly-named *_run.log files)
transcript
**/transcript
# Wave database
*.wlf
*.wlf.dpd
# Internal lib files (only show up if work/ slips through)
*.qdb
*.qpg
*.qtl

# ---- OpenLane ----
# Per-flow run outputs (DEF/LEF/GDS intermediates, ~100s of MB per run).
# We keep only the curated reports copied into codefest/cf07/synth/ and
# project/m3/synth/.
**/codefest/**/runs/
**/synth/runs/
# OpenLane SystemVerilog-frontend transient parse cache
**/slpp_all/

# ---- Cadence Genus ----
# Per-run PBS scratch dir (host- and PID-specific, contains lib_script etc.)
.pbs_*/
**/.pbs_*/
# Sweep netlists/SDCs are large (softmax_unit.v ~350 MB, sys_32x32 even
# bigger) and trivially regeneratable from RTL via run_genus_sweep.do.
# We keep the reports/ subdirs because that's the actual sweep data.
**/out_sweep/**/*.v
**/out_sweep/**/*.sdc
# Per-point Genus stdout transcripts -- big, and the combined sweep_all.log
# plus error.txt already capture what matters.
logs_sweep/
**/logs_sweep/
# Genus session bookkeeping (timestamps, tool-state markers)
.rs_*.tstamp
**/.rs_*.tstamp
# Cadence formal-verification intermediates -- auto-generated per
# elaborate (~1.6 M lines across all blocks). Not needed for sweep
# deliverable; regenerated on every run.
fv/
**/fv/

# ---- Cadence Innovus (phobos hierarchical PnR flow) ----
# Phase 4/5 outputs from run_phobos_hier.sh: DEF (60 MB), GDS (100+ MB),
# SPEF, post-route netlist, per-stage .enc snapshots. All regeneratable
# from the Genus netlist + SDC by re-running phase 4. We keep the
# reports/ and sta/ subdirs because those carry the headline numbers
# (mc_summary.rpt, timing/power per corner).
**/out_innovus/**/*.def
**/out_innovus/**/*.gds
**/out_innovus/**/*.gds.gz
**/out_innovus/**/*.spef
**/out_innovus/**/*.v
**/out_innovus/**/*.enc
**/out_innovus/**/*.enc.dat/
# Per-phase Genus/Innovus stdout transcripts from run_phobos_hier.sh
logs_hier/
**/logs_hier/

# ---- Python ----
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ---- Editors / OS ----
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ---- Misc build artifacts ----
*.exe
*.log.bak
*.bak
*~

# Note: explicit deliverable logs are NOT ignored:
#   project/m2/sim/compute_core_run.log
#   project/m2/sim/interface_run.log
#   project/m2/sim/precision_results.txt
# Those are tracked normally.
